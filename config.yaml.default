# config.yaml.default — reference template for Pueo configuration
# Run setup.sh to generate config.yaml interactively, or copy this file:
#   cp config.yaml.default config.yaml
# config.yaml is gitignored and never committed.

home_assistant:
  known_version: ""              # Populated by setup.sh; Pueo warns at startup if HA has updated
  host: "homeassistant.local"        # IP address or mDNS hostname of your HA server
  user: "root"                        # SSH username (root for the Terminal & SSH App)
  ssh_key_path: "~/.ssh/id_ed25519"  # Local path to the SSH private key
  api_token: ""                        # HA long-lived access token (required for NetAlertX steps 6–7)
  config_path: "/config/configuration.yaml"  # Path to configuration.yaml on the HA host
  log_path: "/config/home-assistant.log"     # Legacy: no longer used by the monitor (which now uses 'ha core logs --follow')

ollama:
  model: "qwen2.5-coder:7b"          # Primary model for config analysis and repair
  endpoint: "http://localhost:11434"  # Ollama API endpoint (default local)

netalertx:
  enabled: false                              # Set to true to activate all NetAlertX features
  deployment: "auto"                          # auto | addon | docker — how NetAlertX is deployed
  host: ""                                    # NetAlertX host (default: same as home_assistant.host)
  api_port: 20212                             # NetAlertX REST API port
  api_token: ""                               # Required when netalertx.enabled = true
  ssh_host: ""                                # SSH host for NetAlertX (default: same as home_assistant.host)
  ssh_user: ""                                # SSH user for NetAlertX (default: same as home_assistant.user)
  ssh_key_path: ""                            # SSH key for NetAlertX (default: same as home_assistant.ssh_key_path)
  addon_repository_url: "https://github.com/jokob-sk/NetAlertX"  # HA add-on repository URL
  addon_slug: ""                              # Leave blank to auto-resolve from Supervisor store
  scan_interface: ""                          # Network interface for scanning (blank = auto-detect)
  auto_generated_name_patterns:               # Regex patterns identifying auto-generated device names
    - "^unknown-"
    - "^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$"
  max_scan_age_minutes: 20                    # Alert if no scan completed within this window
  mqtt_subscribe: true                        # Subscribe to NetAlertX MQTT device presence events
  log_container_name: "netalertx"            # Docker container name (Docker deployments only)
  max_db_history_rows: 100000                 # Trigger DB cleanup above this row count

agent:
  db_path: "ha_agent_state.db"       # Local SQLite file for state and backup history
  log_confidence_threshold: 0.7      # Minimum AI confidence score to trigger autonomous repair
  self_healing_enabled: true         # Set to false to run in diagnostic-only mode
  ssh_retry_attempts: 3              # Max SSH connection retries before giving up (0 = infinite)
  ssh_retry_base_delay: 2.0          # Base delay in seconds for SSH retry exponential backoff
  debounce_window_seconds: 30        # Suppress repeated repair triggers within this window
  repair_cooldown_seconds: 300       # Pause after a repair before re-arming the monitor
  max_repairs_per_hour: 10           # Hard cap on autonomous repair attempts per hour
  log_level: "INFO"                  # Logging verbosity: DEBUG, INFO, WARNING, ERROR, CRITICAL
  log_file: "pueo.log"               # Path to the structured JSON log file
  max_prompt_tokens: 7000            # Maximum tokens sent to Ollama per request (8k context minus headroom)
  notifier: "file"                   # HITL notifier backend: "file", "ntfy", or "webhook"
  notify_url: ""                     # URL for ntfy topic or webhook endpoint (unused for "file" notifier)
  notify_watch_dir: "hitl/"          # Directory watched by FileNotifier for .approved/.rejected signals
  hitl_always: false                 # Set to true to require human approval before every repair, not just CRITICAL
  autonomy_level: 2                  # 1=report-only · 2=suggest(approve all) · 3=guided(auto-LOW) · 4=autonomous(auto-LOW/MED/HIGH)
  dashboard_port: 8080               # Port for the HITL web dashboard (python main.py --mode dashboard)
